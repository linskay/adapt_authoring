            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": ""
          },
          "item-ui-color-inverted-locked": {
            "title": "Цвет интерфейса элемента - инвертированный заблокированный",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": "Определяет цвет текста/иконки интерфейса элемента при блокировке. Должен быть цветом, который обеспечивает хороший контраст с цветом заблокированного интерфейса элемента."
          },
          "item-ui-color-disabled": {
            "title": "Цвет интерфейса элемента - отключенный",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": ""
          },
          "item-ui-color-inverted-disabled": {
            "title": "Цвет интерфейса элемента - инвертированный отключенный",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": "Определяет цвет текста/иконки интерфейса элемента при отключении. Должен быть цветом, который обеспечивает хороший контраст с цветом отключенного интерфейса элемента."
          }
        }
