          "item-ui-color-inverted-visited": {
            "title": "Цвет интерфейса элемента - инвертированный посещенный",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": "Определяет цвет текста/иконки интерфейса элемента при посещении. Должен быть цветом, который обеспечивает хороший контраст с цветом посещенного интерфейса элемента."
          },
