            "title": "Цвет интерфейса",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": "Определяет глобальную цветовую схему пользовательского интерфейса для навигации, уведомлений и боковой панели."
          },
          "ui-color-inverted": {
            "title": "Цвет интерфейса - инвертированный",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": "Определяет глобальный цвет текста/иконки пользовательского интерфейса. Должен быть цветом, который обеспечивает хороший контраст с глобальным цветом пользовательского интерфейса."
          }
        }
      },

      "_validation": {
        "type": "object",
        "required": false,
        "title": "Состояния валидации",
        "properties": {
          "validation-success": {
            "title": "Цвет успешной проверки",
