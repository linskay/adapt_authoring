{
  "type": "object",
  "$schema": "http://json-schema.org/draft-04/schema",
  "id": "http://jsonschema.net",
  "$ref": "http://localhost/plugins/content/theme/model.schema",
  "properties": {
    "variables": {

      "_global": {
        "type": "object",
        "required": false,
        "title": "Глобальные",
        "properties": {
          "font-color": {
            "title": "Цвет шрифта",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": "Глобальный цвет шрифта основного текста."
          },
          "font-color-inverted": {
            "title": "Цвет шрифта инвертированный",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": "Глобальный инвертированный цвет шрифта основного текста. Либо осветленная, либо затемненная альтернатива цвету шрифта."
          },
          "link": {
            "title": "Цвет шрифта ссылки",
            "type": "string",
            "inputType": "ColourPicker",
            "default": ""
          },
          "link-inverted": {
            "title": "Цвет шрифта ссылки - инвертированный",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": "Глобальный инвертированный цвет шрифта ссылки. Либо осветленная, либо затемненная альтернатива цвету ссылки."
          },
          "link-hover": {
            "title": "Цвет шрифта ссылки - при наведении",
            "type": "string",
            "inputType": "ColourPicker",
            "default": ""
          },
          "link-inverted-hover": {
            "title": "Цвет шрифта ссылки - инвертированный при наведении",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": "Глобальный инвертированный цвет шрифта ссылки при наведении. Либо осветленная, либо затемненная альтернатива цвету ссылки при наведении."
          },
          "heading-color": {
            "title": "Цвет заголовка",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": "Глобальный цвет заголовка."
          },
          "heading-color-inverted": {
            "title": "Цвет заголовка - инвертированный",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": "Глобальный инвертированный цвет заголовка. Либо осветленная, либо затемненная альтернатива цвету заголовка."
          }
        }
      },

      "_items": {
        "type": "object",
        "required": false,
        "title": "Элементы контента (компоненты)",
        "properties": {
          "item-color": {
            "title": "Цвет элемента",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": "Определяет выбираемые области или точки интереса в компонентах."
          },
          "item-color-inverted": {
            "title": "Цвет элемента - инвертированный",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": "Определяет цвет текста/иконки элемента. Должен быть цветом, который обеспечивает хороший контраст с цветом элемента."
          },
          "item-color-hover": {
            "title": "Цвет элемента - при наведении",
            "type": "string",
            "inputType": "ColourPicker",
            "default": ""
          },
          "item-color-inverted-hover": {
            "title": "Цвет элемента - инвертированный при наведении",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": "Определяет цвет текста/иконки элемента при наведении. Должен быть цветом, который обеспечивает хороший контраст с цветом элемента при наведении."
          },
          "item-color-focus": {
            "title": "Цвет элемента - при фокусе",
            "type": "string",
            "inputType": "ColourPicker",
            "default": ""
          },
          "item-color-inverted-focus": {
            "title": "Цвет элемента - инвертированный при фокусе",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": "Определяет цвет текста/иконки элемента при фокусе. Должен быть цветом, который обеспечивает хороший контраст с цветом элемента при фокусе."
          },
          "item-color-selected": {
            "title": "Цвет элемента - выбранный",
            "type": "string",
            "inputType": "ColourPicker",
            "default": ""
          },
          "item-color-inverted-selected": {
            "title": "Цвет элемента - инвертированный выбранный",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": "Определяет цвет текста/иконки элемента при выборе. Должен быть цветом, который обеспечивает хороший контраст с цветом выбранного элемента."
          },
          "visited": {
            "title": "Цвет элемента - посещенный",
            "type": "string",
            "inputType": "ColourPicker",
            "default": ""
          },
          "visited-inverted": {
            "title": "Цвет элемента - инвертированный посещенный",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": "Определяет цвет текста/иконки элемента при посещении. Должен быть цветом, который обеспечивает хороший контраст с цветом посещенного элемента."
          },
          "item-color-disabled": {
            "title": "Цвет элемента - отключенный",
            "type": "string",
            "inputType": "ColourPicker",
            "default": ""
          },
          "item-color-inverted-disabled": {
            "title": "Цвет элемента - инвертированный отключенный",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": "Определяет цвет текста/иконки элемента при отключении. Должен быть цветом, который обеспечивает хороший контраст с цветом отключенного элемента."
          }
        }
      },

      "_itemsUi": {
        "type": "object",
        "required": false,
        "title": "UI элементов контента (действие, не контент)",
        "properties": {
          "item-ui-color": {
            "title": "Цвет интерфейса элемента",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": "Определяет выбираемые области в компонентах, которые не содержат контент курса."
          },
          "item-ui-color-inverted": {
            "title": "Цвет интерфейса элемента - инвертированный",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": "Определяет цвет текста/иконки интерфейса элемента. Должен быть цветом, который обеспечивает хороший контраст с цветом интерфейса элемента."
          },
          "item-ui-color-hover": {
            "title": "Цвет интерфейса элемента - при наведении",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": ""
          },
          "item-ui-color-inverted-hover": {
            "title": "Цвет интерфейса элемента - инвертированный при наведении",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": "Определяет цвет текста/иконки интерфейса элемента при наведении. Должен быть цветом, который обеспечивает хороший контраст с цветом интерфейса элемента при наведении."
          },
          "item-ui-color-focus": {
            "title": "Цвет интерфейса элемента - при фокусе",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": ""
          },
          "item-ui-color-inverted-focus": {
            "title": "Цвет интерфейса элемента - инвертированный при фокусе",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": "Определяет цвет текста/иконки интерфейса элемента при фокусе. Должен быть цветом, который обеспечивает хороший контраст с цветом интерфейса элемента при фокусе."
          },
          "item-ui-color-selected": {
            "title": "Цвет интерфейса элемента - выбранный",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
            "help": ""
          },
          "item-ui-color-inverted-selected": {
            "title": "Цвет интерфейса элемента - инвертированный выбранный",
            "type": "string",
            "inputType": "ColourPicker",
            "default": "",
