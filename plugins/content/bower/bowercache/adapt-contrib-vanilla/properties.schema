                  "type": "object",
                  "required": false,
                  "legend": "Стили фонового изображения страницы",
                  "properties": {
                    "_backgroundRepeat": {
                      "type": "string",
                      "required": false,
                      "default": "no-repeat",
                      "inputType": {"type":"Select", "options":["repeat","repeat-x","repeat-y","no-repeat"]},
                      "title": "Установить, повторяется ли/как повторяется фоновое изображение",
                      "help": "Repeat-x: фоновое изображение повторяется только по горизонтали. Repeat-y: фоновое изображение повторяется только по вертикали."
                    },
                    "_backgroundSize": {
                      "type": "string",
                      "required": false,
                      "default": "cover",
                      "inputType": {"type":"Select", "options":["auto","cover","contain","100% 100%"]},
                      "title": "Установить размер фонового изображения",
                      "help": "Auto: фоновое изображение отображается в исходном размере. Cover: изменить размер фонового изображения, чтобы оно покрывало весь контейнер, даже если для этого придется растянуть или обрезать изображение. Contain: изменить размер фонового изображения, чтобы убедиться, что изображение полностью видно. 100% 100%: изменить размер фонового изображения, чтобы он соответствовал размерам контейнера."
                    },
                    "_backgroundPosition": {
                      "type": "string",
                      "required": false,
                      "default": "center top",
