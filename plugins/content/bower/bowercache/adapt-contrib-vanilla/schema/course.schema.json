{
  "$anchor": "vanilla-course",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$patch": {
    "source": {
      "$ref": "course"
    },
    "with": {
      "properties": {
        "_vanilla": {
          "type": "object",
          "title": "Тема",
          "default": {},
          "properties": {
            "_favIcon": {
              "type": "object",
              "default": {},
              "title": "Иконка сайта",
              "properties": {
                "_src": {
                  "type": "string",
                  "title": "Изображение",
                  "description": "Выберите favicon для улучшения пользовательского опыта и обеспечения согласованности бренда. Он будет отображаться в таких местах, как адресная строка вашего браузера, вкладки страниц и меню закладок. Обычно favicon имеет размер 16 x 16 пикселей и хранится в формате GIF, PNG или ICO.",
                  "_backboneForms": {
                    "type": "Asset",
                    "media": "image"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
