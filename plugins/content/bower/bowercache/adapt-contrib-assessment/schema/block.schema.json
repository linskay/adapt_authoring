{
  "$anchor": "assessment-block",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$patch": {
    "source": {
      "$ref": "block"
    },
    "with": {
      "properties": {
        "_assessment": {
          "type": "object",
          "title": "Тест",
          "default": {},
          "properties": {
            "_quizBankID": {
              "type": "number",
              "title": "ID банка",
              "description": "Используется для группировки блоков компонентов вопросов в связанные банки. Работает в сочетании со свойством 'Количество вопросов' при использовании банков вопросов",
              "default": 1,
              "_backboneForms": {
                "editorAttrs": {
                  "step": 1,
                  "min": 1
                }
              }
            }
          }
        }
      }
    }
  }
}
