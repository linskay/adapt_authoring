{
  "$anchor": "slider-course",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$patch": {
    "source": {
      "$ref": "course"
    },
    "with": {
      "properties": {
        "_globals": {
          "type": "object",
          "default": {},
          "properties": {
            "_components": {
              "type": "object",
              "default": {},
              "properties": {
                "_slider": {
                  "type": "object",
                  "title": "Слайдер",
                  "default": {},
                  "properties": {
                    "ariaRegion": {
                      "type": "string",
                      "title": "Область ARIA",
                      "default": "Слайдер. Ответьте на вопрос, выбрав значение на шкале, а затем нажмите «Отправить».",
                      "_adapt": {
                        "translatable": true
                      }
                    },
                    "labelStart": {
                      "type": "string",
                      "title": "Метка ARIA начала шкалы",
                      "default": "Начало шкалы",
                      "_adapt": {
                        "translatable": true
                      }
                    },
                    "labelEnd": {
                      "type": "string",
                      "title": "Метка ARIA конца шкалы",
                      "default": "Конец шкалы",
                      "_adapt": {
                        "translatable": true
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
