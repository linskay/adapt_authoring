{
  "$anchor": "slider-component",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$merge": {
    "source": {
      "$ref": "component"
    },
    "with": {
      "required": [
        "ariaScaleName",
        "_attempts",
        "_scaleStart",
        "_scaleEnd"
      ],
      "properties": {
        "_supportedLayout": {
          "type": "string",
          "title": "Поддерживаемый макет",
          "default": "both",
          "enum": [
            "full-width",
            "half-width",
            "both"
          ],
          "_adapt": {
            "editorOnly": true
          }
        },
        "instruction": {
          "type": "string",
          "title": "Инструкция",
          "default": "Перетащите ползунок, чтобы сделать свой выбор, и нажмите «Отправить».",
          "_adapt": {
            "translatable": true
          }
        },
        "ariaQuestion": {
          "type": "string",
          "title": "Вопрос ARIA",
          "description": "Это будет зачитано программами чтения с экрана вместо чтения полей 'Заголовок', 'Тело' и 'Инструкция' при фокусировке на параметрах. Чтобы быть ясным и кратким, убедитесь, что текст охватывает только связанный вопрос.",
          "default": "",
          "_adapt": {
            "translatable": true
          }
        },
        "ariaScaleName": {
          "type": "string",
          "title": "Имя шкалы ARIA",
          "description": "Это будет зачитано программами чтения с экрана при фокусировке на вводе шкалы (ручке ползунка). Соответствующее имя должно давать контекст того, что измеряет шкала.",
          "default": "",
          "_adapt": {
            "translatable": true
          }
        },
        "_attempts": {
          "type": "number",
          "title": "Допустимое количество попыток",
          "description": "Сколько попыток разрешено учащемуся",
          "default": 1
        },
        "_canShowModelAnswer": {
          "type": "boolean",
          "title": "Включить переключатель правильного ответа",
          "description": "Разрешить пользователю просматривать 'правильный ответ', если он ответит на вопрос неправильно",
          "default": true
        },
        "_canShowCorrectness": {
          "type": "boolean",
          "title": "Включить отображение правильности",
          "description": "Если включено, это заменяет соответствующую кнопку-переключатель 'правильный ответ' и отображает правильность непосредственно на компоненте",
          "default": false
        },
        "_canShowFeedback": {
          "type": "boolean",
          "title": "Включить обратную связь",
          "default": true
        },
        "_canShowMarking": {
          "type": "boolean",
          "title": "Включить оценку",
          "default": true
        },
        "_shouldDisplayAttempts": {
          "type": "boolean",
          "title": "Показывать количество оставшихся попыток",
          "default": false
        },
        "_questionWeight": {
          "type": "number",
          "title": "Вес вопроса",
          "description": "Насколько ценен этот вопрос",
          "default": 1
        },
        "_recordInteraction": {
          "type": "boolean",
          "title": "Записывать взаимодействие",
          "description": "Если отключено, запись ответа(ов) пользователя на этот вопрос в cmi.interactions в LMS будет отключена только для этого компонента.",
          "default": true
        },
        "labelStart": {
          "type": "string",
          "title": "Метка начала шкалы",
          "default": "",
          "_adapt": {
            "translatable": true
          }
        },
        "labelEnd": {
          "type": "string",
          "title": "Метка конца шкалы",
          "default": "",
          "_adapt": {
            "translatable": true
          }
        },
        "_scaleStart": {
          "type": "number",
          "title": "Начальное число шкалы",
          "default": 1
        },
        "_scaleEnd": {
          "type": "number",
          "title": "Конечное число шкалы",
          "default": 10
        },
        "_scaleStep": {
          "type": "number",
          "title": "Шаг шкалы",
          "description": "На какую величину должна увеличиваться шкала",
          "default": 1,
          "exclusiveMinimum": 0
        },
        "scaleStepPrefix": {
          "type": "string",
          "title": "Префикс для каждого шага ползунка",
          "description": "Например, '$' можно использовать в качестве префикса для обозначения валюты в долларах (например, $100)",
          "default": "",
          "_adapt": {
            "translatable": true
          }
        },
        "scaleStepSuffix": {
          "type": "string",
          "title": "Суффикс для каждого шага ползунка",
          "description": "Например, 'V' можно использовать в качестве суффикса для обозначения напряжения (например, 4V)",
          "default": "",
          "_adapt": {
            "translatable": true
          }
        },
        "_correctAnswer": {
          "type": "string",
          "title": "Правильный ответ",
          "description": "Правильный ответ на шкале",
          "default": ""
        },
        "_correctRange": {
          "type": "object",
          "title": "Правильный диапазон",
          "default": {},
          "properties": {
            "_bottom": {
              "type": "number",
              "title": "Минимум",
              "description": "Правильный нижний диапазон ответа на шкале -- игнорируется, когда установлен 'Правильный ответ'",
              "default": 0
            },
            "_top": {
              "type": "number",
              "title": "Максимум",
              "description": "Правильный верхний диапазон ответа на шкале -- игнорируется, когда установлен 'Правильный ответ'",
              "default": 0
            }
          }
        },
        "_showScaleIndicator": {
          "type": "boolean",
          "title": "Показывать индикатор положения",
          "description": "Контролирует, должен ли отображаться индикатор положения на шкале",
          "default": true
        },
        "_showNumber": {
          "type": "boolean",
          "title": "Показывать номер на индикаторе",
          "description": "Контролирует, должен ли отображаться номер положения на индикаторе",
          "default": true
        },
        "_showScale": {
          "type": "boolean",
          "title": "Показывать шкалу",
          "description": "Контролирует, показывать ли линии и номера шкалы",
          "default": true
        },
        "_showScaleNumbers": {
          "type": "boolean",
          "title": "Показывать номера на шкале",
          "description": "Контролирует, должны ли отображаться номера на шкале",
          "default": true
        },
        "_feedback": {
          "type": "object",
          "title": "Обратная связь",
          "default": {},
          "properties": {
            "title": {
              "type": "string",
              "title": "Заголовок",
              "description": "Текст заголовка для обратной связи",
              "default": "",
              "_adapt": {
                "translatable": true
              }
            },
            "altTitle": {
              "type": "string",
              "title": "Альтернативный заголовок обратной связи",
              "description": "Текст, зачитываемый программами чтения с экрана, если нет визуального заголовка",
              "default": "",
              "_adapt": {
                "translatable": true
              }
            },
            "correct": {
              "type": "string",
              "title": "Правильная обратная связь",
              "description": "Обратная связь на правильный ответ на этот вопрос",
              "default": "",
              "_adapt": {
                "translatable": true
              },
              "_backboneForms": "TextArea"
            },
            "_incorrect": {
              "type": "object",
              "title": "Неправильно",
              "default": {},
              "properties": {
                "final": {
                  "type": "string",
                  "title": "Обратная связь по умолчанию для неправильного ответа",
                  "description": "Обратная связь на неправильный ответ для последней попытки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  },
                  "_backboneForms": "TextArea"
                },
                "notFinal": {
                  "type": "string",
                  "title": "Обратная связь для повторной попытки",
                  "description": "Обратная связь на неправильный ответ для любой попытки, кроме последней. Если вы оставите это поле пустым, будет использоваться обратная связь по умолчанию для неправильного ответа.",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  },
                  "_backboneForms": "TextArea"
                }
              }
            }
          }
        },
        "_buttons": {
          "type": "object",
          "title": "Переопределение кнопок",
          "default": {},
          "properties": {
            "_submit": {
              "type": "object",
              "title": "Отправить",
              "default": {},
              "properties": {
                "buttonText": {
                  "type": "string",
                  "title": "Текст кнопки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "ariaLabel": {
                  "type": "string",
                  "title": "Метка ARIA",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            },
            "_reset": {
              "type": "object",
              "title": "Сброс",
              "default": {},
              "properties": {
                "buttonText": {
                  "type": "string",
                  "title": "Текст кнопки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "ariaLabel": {
                  "type": "string",
                  "title": "Метка ARIA",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            },
            "_showCorrectAnswer": {
              "type": "object",
              "title": "Показать правильный ответ",
              "default": {},
              "properties": {
                "buttonText": {
                  "type": "string",
                  "title": "Текст кнопки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "ariaLabel": {
                  "type": "string",
                  "title": "Метка ARIA",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            },
            "_hideCorrectAnswer": {
              "type": "object",
              "title": "Скрыть правильный ответ",
              "default": {},
              "properties": {
                "buttonText": {
                  "type": "string",
                  "title": "Текст кнопки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "ariaLabel": {
                  "type": "string",
                  "title": "Метка ARIA",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            },
            "_showFeedback": {
              "type": "object",
              "title": "Показать обратную связь",
              "default": {},
              "properties": {
                "buttonText": {
                  "type": "string",
                  "title": "Текст кнопки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "ariaLabel": {
                  "type": "string",
                  "title": "Метка ARIA",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            },
            "remainingAttemptsText": {
              "type": "string",
              "title": "Метка оставшихся попыток",
              "default": "",
              "_adapt": {
                "translatable": true
              }
            },
            "remainingAttemptText": {
              "type": "string",
              "title": "Метка последней попытки",
              "default": "",
              "_adapt": {
                "translatable": true
              }
            }
          }
        }
      }
    }
  }
}
