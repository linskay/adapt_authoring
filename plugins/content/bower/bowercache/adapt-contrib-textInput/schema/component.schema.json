{
  "$anchor": "textinput-component",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$merge": {
    "source": {
      "$ref": "component"
    },
    "with": {
      "required": [
        "_attempts"
      ],
      "properties": {
        "_supportedLayout": {
          "type": "string",
          "title": "Поддерживаемый макет",
          "default": "both",
          "enum": [
            "full-width",
            "half-width",
            "both"
          ],
          "_adapt": {
            "editorOnly": true
          }
        },
        "instruction": {
          "type": "string",
          "title": "Инструкция",
          "default": "Введите свой ответ и нажмите «Отправить».",
          "_adapt": {
            "translatable": true
          }
        },
        "ariaQuestion": {
          "type": "string",
          "title": "Вопрос ARIA",
          "description": "Это будет зачитано программами чтения с экрана вместо чтения полей 'Заголовок', 'Тело' и 'Инструкция' при фокусировке на параметрах. Чтобы быть ясным и кратким, убедитесь, что текст охватывает только связанный вопрос.",
          "default": "",
          "_adapt": {
            "translatable": true
          }
        },
        "_items": {
          "type": "array",
          "title": "Элементы",
          "items": {
            "type": "object",
            "properties": {
              "_answers": {
                "type": "array",
                "title": "Ответы",
                "items": {
                  "type": "string"
                }
              },
              "prefix": {
                "type": "string",
                "title": "Префикс",
                "default": "",
                "_adapt": {
                  "translatable": true
                }
              },
              "suffix": {
                "type": "string",
                "title": "Суффикс",
                "default": "",
                "_adapt": {
                  "translatable": true
                }
              },
              "placeholder": {
                "type": "string",
                "title": "Заполнитель",
                "description": "Подсказка или ожидаемое значение поля ввода",
                "default": "",
                "_adapt": {
                  "translatable": true
                }
              }
            }
          }
        },
        "_attempts": {
          "type": "number",
          "title": "Допустимое количество попыток",
          "description": "Сколько попыток разрешено учащемуся",
          "default": 1
        },
        "_canShowModelAnswer": {
          "type": "boolean",
          "title": "Включить переключатель правильного ответа",
          "description": "Разрешить пользователю просматривать 'правильный ответ', если он ответит на вопрос неправильно",
          "default": true
        },
        "_canShowCorrectness": {
          "type": "boolean",
          "title": "Включить отображение правильных ответов после отправки",
          "description": "Если включено, это заменяет соответствующую кнопку-переключатель 'правильный ответ', и под введенным текстом отображается список правильных вариантов, разделенных запятыми.",
          "default": false
        },
        "_canShowFeedback": {
          "type": "boolean",
          "title": "Включить обратную связь",
          "default": true
        },
        "_canShowMarking": {
          "type": "boolean",
          "title": "Включить оценку",
          "default": true
        },
        "_shouldDisplayAttempts": {
          "type": "boolean",
          "title": "Показывать количество оставшихся попыток",
          "default": false
        },
        "_isRandom": {
          "type": "boolean",
          "title": "Перемешать элементы",
          "default": false
        },
        "_recordInteraction": {
          "type": "boolean",
          "title": "Записывать взаимодействие",
          "description": "Если отключено, запись ответа(ов) пользователя на этот вопрос в cmi.interactions в LMS будет отключена только для этого компонента.",
          "default": true
        },
        "_questionWeight": {
          "type": "number",
          "title": "Вес вопроса",
          "description": "Насколько ценен этот вопрос",
          "default": 1
        },
        "_allowsAnyCase": {
          "type": "boolean",
          "title": "Отключить чувствительность к регистру",
          "description": "Должна ли проверка ответа(ов) пользователя быть нечувствительной к регистру или чувствительной к регистру?",
          "default": false
        },
        "_allowsPunctuation": {
          "type": "boolean",
          "title": "Удалить знаки препинания из пользовательского ввода",
          "default": false
        },
        "_feedback": {
          "type": "object",
          "title": "Обратная связь",
          "default": {},
          "properties": {
            "title": {
              "type": "string",
              "title": "Заголовок",
              "description": "Текст заголовка для обратной связи",
              "default": "",
              "_adapt": {
                "translatable": true
              }
            },
            "altTitle": {
              "type": "string",
              "title": "Альтернативный заголовок обратной связи",
              "description": "Текст, зачитываемый программами чтения с экрана, если нет визуального заголовка",
              "default": "",
              "_adapt": {
                "translatable": true
              }
            },
            "correct": {
              "type": "string",
              "title": "Правильная обратная связь",
              "description": "Обратная связь на правильный ответ на этот вопрос",
              "default": "",
              "_adapt": {
                "translatable": true
              },
              "_backboneForms": "TextArea"
            },
            "_incorrect": {
              "type": "object",
              "title": "Неправильно",
              "default": {},
              "properties": {
                "final": {
                  "type": "string",
                  "title": "Обратная связь по умолчанию для неправильного ответа",
                  "description": "Обратная связь на неправильный ответ для последней попытки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  },
                  "_backboneForms": "TextArea"
                },
                "notFinal": {
                  "type": "string",
                  "title": "Обратная связь для повторной попытки",
                  "description": "Обратная связь на неправильный ответ для любой попытки, кроме последней. Если вы оставите это поле пустым, будет использоваться обратная связь по умолчанию для неправильного ответа.",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  },
                  "_backboneForms": "TextArea"
                }
              }
            },
            "_partlyCorrect": {
              "type": "object",
              "title": "Частично правильно",
              "default": {},
              "properties": {
                "final": {
                  "type": "string",
                  "title": "Обратная связь по умолчанию для частично правильного ответа",
                  "description": "Обратная связь на частично правильный ответ для последней попытки. Если вы оставите это поле пустым, будет использоваться обратная связь по умолчанию для неправильного ответа.",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  },
                  "_backboneForms": "TextArea"
                },
                "notFinal": {
                  "type": "string",
                  "title": "Обратная связь для повторной попытки",
                  "description": "Обратная связь на частично правильный ответ для любой попытки, кроме последней. Если вы оставите это поле пустым, будет использоваться обратная связь по умолчанию для частично правильного ответа.",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  },
                  "_backboneForms": "TextArea"
                }
              }
            }
          }
        },
        "_buttons": {
          "type": "object",
          "title": "Переопределение кнопок",
          "default": {},
          "properties": {
            "_submit": {
              "type": "object",
              "title": "Отправить",
              "default": {},
              "properties": {
                "buttonText": {
                  "type": "string",
                  "title": "Текст кнопки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "ariaLabel": {
                  "type": "string",
                  "title": "Метка ARIA",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            },
            "_reset": {
              "type": "object",
              "title": "Сброс",
              "default": {},
              "properties": {
                "buttonText": {
                  "type": "string",
                  "title": "Текст кнопки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "ariaLabel": {
                  "type": "string",
                  "title": "Метка ARIA",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            },
            "_showCorrectAnswer": {
              "type": "object",
              "title": "Показать правильный ответ",
              "default": {},
              "properties": {
                "buttonText": {
                  "type": "string",
                  "title": "Текст кнопки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "ariaLabel": {
                  "type": "string",
                  "title": "Метка ARIA",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            },
            "_hideCorrectAnswer": {
              "type": "object",
              "title": "Скрыть правильный ответ",
              "default": {},
              "properties": {
                "buttonText": {
                  "type": "string",
                  "title": "Текст кнопки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "ariaLabel": {
                  "type": "string",
                  "title": "Метка ARIA",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            },
            "_showFeedback": {
              "type": "object",
              "title": "Показать обратную связь",
              "default": {},
              "properties": {
                "buttonText": {
                  "type": "string",
                  "title": "Текст кнопки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "ariaLabel": {
                  "type": "string",
                  "title": "Метка ARIA",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            },
            "remainingAttemptsText": {
              "type": "string",
              "title": "Метка оставшихся попыток",
              "default": "",
              "_adapt": {
                "translatable": true
              }
            },
            "remainingAttemptText": {
              "type": "string",
              "title": "Метка последней попытки",
              "default": "",
              "_adapt": {
                "translatable": true
              }
            }
          }
        }
      }
    }
  }
}
