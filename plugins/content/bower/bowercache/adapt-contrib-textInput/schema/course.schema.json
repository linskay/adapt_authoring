{
  "$anchor": "textinput-course",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$patch": {
    "source": {
      "$ref": "course"
    },
    "with": {
      "properties": {
        "_globals": {
          "type": "object",
          "default": {},
          "properties": {
            "_components": {
              "type": "object",
              "default": {},
              "properties": {
                "_textinput": {
                  "type": "object",
                  "title": "Текстовый ввод",
                  "default": {},
                  "properties": {
                    "ariaRegion": {
                      "type": "string",
                      "title": "Область ARIA",
                      "default": "Текстовый ввод. Введите свой ответ и нажмите «Отправить».",
                      "_adapt": {
                        "translatable": true
                      }
                    },
                    "correctAnswerPrefix": {
                      "type": "string",
                      "title": "Префикс ARIA для правильного ответа",
                      "description": "Если включено _canShowCorrectness, этот текст представляет собой префикс для правильного варианта, отображаемого под введенным текстом",
                      "default": "Правильный ответ:",
                      "_adapt": {
                        "translatable": true
                      }
                    },
                    "correctAnswersPrefix": {
                      "type": "string",
                      "title": "Префикс ARIA для правильных ответов",
                      "description": "Если включено _canShowCorrectness, этот текст представляет собой префикс для списка правильных вариантов, разделенных запятыми, отображаемого под введенным текстом",
                      "default": "Принимаются правильные ответы, включая",
                      "_adapt": {
                        "translatable": true
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
