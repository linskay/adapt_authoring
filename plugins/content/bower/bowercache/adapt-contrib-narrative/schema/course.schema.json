{
  "$anchor": "narrative-course",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$patch": {
    "source": {
      "$ref": "course"
    },
    "with": {
      "properties": {
        "_globals": {
          "type": "object",
          "default": {},
          "properties": {
            "_components": {
              "type": "object",
              "default": {},
              "properties": {
                "_narrative": {
                  "type": "object",
                  "title": "Повествование",
                  "default": {},
                  "properties": {
                    "ariaRegion": {
                      "type": "string",
                      "title": "Область ARIA",
                      "default": "Слайд-шоу. Нажмите кнопку 'далее', чтобы продолжить.",
                      "_adapt": {
                        "translatable": true
                      }
                    },
                    "previous": {
                      "type": "string",
                      "title": "Предыдущий",
                      "default": "{{#if isAtStart}}{{_globals._accessibility._ariaLabels.previous}}{{else}}{{#if title}}Назад к {{{title}}}{{else}}{{_globals._accessibility._ariaLabels.previous}}{{/if}} (элемент {{itemNumber}} из {{totalItems}}){{/if}}",
                      "_adapt": {
                        "translatable": true
                      }
                    },
                    "next": {
                      "type": "string",
                      "title": "Следующий",
                      "default": "{{#if isAtEnd}}{{_globals._accessibility._ariaLabels.next}}{{else}}{{#if title}}Вперед к {{{title}}}{{else}}{{_globals._accessibility._ariaLabels.next}}{{/if}} (элемент {{itemNumber}} из {{totalItems}}){{/if}}",
                      "_adapt": {
                        "translatable": true
                      }
                    },
                    "titleDialog": {
                      "type": "string",
                      "title": "Заголовок диалогового окна по умолчанию",
                      "help": "Резервный заголовок по умолчанию для всплывающих диалоговых окон, если он не установлен для элемента",
                      "default": "Элемент {{itemNumber}} из {{totalItems}}",
                      "_adapt": {
                        "translatable": true
                      }
                    },
                    "titleStrapline": {
                      "type": "string",
                      "title": "Заголовок слогана по умолчанию",
                      "help": "Резервный заголовок по умолчанию для кнопок слогана, если он не установлен для элемента",
                      "default": "Узнать больше",
                      "_adapt": {
                        "translatable": true
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
