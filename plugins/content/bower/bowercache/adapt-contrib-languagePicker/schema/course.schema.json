{
  "$anchor": "languagePicker-course",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$patch": {
    "source": {
      "$ref": "course"
    },
    "with": {
      "properties": {
        "_globals": {
          "type": "object",
          "default": {},
          "properties": {
            "_extensions": {
              "type": "object",
              "default": {},
              "properties": {
                "_languagePicker": {
                  "type": "object",
                  "title": "Выбор языка",
                  "default": {},
                  "properties": {
                    "languageSelector": {
                      "type": "string",
                      "title": "Выбор языка",
                      "default": "Выбор языка",
                      "_adapt": {
                        "translatable": true
                      }
                    },
                    "_navOrder": {
                      "type": "number",
                      "title": "Порядок навигационной панели",
                      "description": "Определяет порядок, в котором кнопка отображается на панели навигации. Отрицательные числа (например, -100) выравниваются по левому краю. Положительные числа (например, 100) выравниваются по правому краю.",
                      "default": 0
                    },
                    "_navTooltip": {
                      "type": "object",
                      "title": "Подсказка навигации",
                      "properties": {
                        "_isEnabled": {
                          "type": "boolean",
                          "title": "Включить подсказку для кнопки навигации",
                          "default": true
                        },
                        "text": {
                          "type": "string",
                          "title": "",
                          "default": "Выберите язык курса",
                          "_adapt": {
                            "translatable": true
                          }
                        }
                      }
                    },
                    "_showLabel": {
                      "type": "boolean",
                      "title": "Включить метку кнопки навигации",
                      "description": "Определяет, отображается ли метка на кнопке навигационной панели.",
                      "default": true
                    },
                    "navigationBarLabel": {
                      "type": "string",
                      "title": "Метка кнопки навигационной панели",
                      "description": "Текст подсказки, отображаемый при наведении.",
                      "default": "Выберите язык курса",
                      "_adapt": {
                        "translatable": true
                      }
                    },
                    "_drawerPosition": {
                      "type": "string",
                      "default": "auto",
                      "title": "Положение ящика",
                      "description": "Определяет начальное положение ящика для открытия.",
                      "enum": [
                        "auto",
                        "left",
                        "right"
                      ]
                    },
                    "_navTooltip": {
                      "type": "object",
                      "title": "Подсказка навигации",
                      "properties": {
                        "_isEnabled": {
                          "type": "boolean",
                          "title": "Включить подсказку для кнопки выбора языка",
                          "default": true
                        },
                        "text": {
                          "type": "string",
                          "title": "Текст подсказки",
                          "default": "Выбор языка",
                          "_adapt": {
                            "translatable": true
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
