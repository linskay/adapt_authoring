{
  "$anchor": "matching-component",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$merge": {
    "source": {
      "$ref": "component"
    },
    "with": {
      "required": [
        "_attempts",
        "placeholder"
      ],
      "properties": {
        "_supportedLayout": {
          "type": "string",
          "title": "Поддерживаемый макет",
          "default": "half-width",
          "enum": [
            "full-width",
            "half-width",
            "both"
          ],
          "_adapt": {
            "editorOnly": true
          }
        },
        "instruction": {
          "type": "string",
          "title": "Инструкция",
          "default": "Выберите вариант из каждого раскрывающегося списка и нажмите «Отправить».",
          "_adapt": {
            "translatable": true
          }
        },
        "ariaQuestion": {
          "type": "string",
          "title": "Вопрос ARIA",
          "description": "Это будет зачитано программами чтения с экрана вместо чтения полей 'Заголовок', 'Тело' и 'Инструкция' при фокусировке на параметрах. Чтобы быть ясным и кратким, убедитесь, что текст охватывает только связанный вопрос.",
          "default": "",
          "_adapt": {
            "translatable": true
          }
        },
        "_attempts": {
          "type": "number",
          "title": "Допустимое количество попыток",
          "description": "Сколько попыток разрешено учащемуся. По умолчанию `1` попытка.",
          "default": 1
        },
        "_canShowModelAnswer": {
          "type": "boolean",
          "title": "Включить переключатель правильного ответа",
          "description": "Разрешить пользователю просматривать 'правильный ответ', если он ответит на вопрос неправильно. По умолчанию true.",
          "default": true
        },
        "_canShowCorrectness": {
          "type": "boolean",
          "title": "Включить отображение правильных ответов после отправки",
          "description": "Если включено, это заменяет соответствующую кнопку-переключатель 'правильный ответ', и под отправленным элементом вопроса отображается список правильных вариантов, разделенных запятыми.",
          "default": false
        },
        "_canShowFeedback": {
          "type": "boolean",
          "title": "Включить обратную связь",
          "default": true
        },
        "_canShowMarking": {
          "type": "boolean",
          "title": "Включить оценку",
          "default": true
        },
        "_shouldResetAllAnswers": {
          "type": "boolean",
          "title": "Сбрасывать правильные ответы между попытками",
          "description": "Контролирует, следует ли сбрасывать все ответы - или только неправильные - при сбросе вопроса. По умолчанию true.",
          "default": true
        },
        "_shouldDisplayAttempts": {
          "type": "boolean",
          "title": "Показывать количество оставшихся попыток",
          "default": false
        },
        "_isRandom": {
          "type": "boolean",
          "title": "Перемешать ответы",
          "default": false
        },
        "_isRandomQuestionOrder": {
          "type": "boolean",
          "title": "Перемешать вопросы",
          "default": false
        },
        "_questionWeight": {
          "type": "number",
          "title": "Вес вопроса",
          "description": "Насколько ценен этот вопрос",
          "default": 1
        },
        "_recordInteraction": {
          "type": "boolean",
          "title": "Записывать взаимодействие",
          "description": "Если отключено, запись ответа(ов) пользователя на этот вопрос в cmi.interactions в LMS будет отключена только для этого компонента. По умолчанию true.",
          "default": true
        },
        "placeholder": {
          "type": "string",
          "title": "Заполнитель",
          "description": "Текст, который будет отображаться вверху каждого списка опций",
          "default": "Пожалуйста, выберите вариант",
          "_adapt": {
            "translatable": true
          }
        },
        "_hasItemScoring": {
          "type": "boolean",
          "title": "Включить оценку по элементам",
          "description": "Если отключено, этот вопрос оценивается в 0 баллов за неправильный ответ и 'Вес вопроса' за правильный. Если включено, этот вопрос оценивается путем суммирования баллов за выбранные варианты. По умолчанию false.",
          "default": false
        },
        "_allowOnlyUniqueAnswers": {
          "type": "boolean",
          "title": "Только уникальные ответы",
          "description": "Если отключено, можно выбрать несколько элементов с одинаковым текстом варианта. По умолчанию false.",
          "default": false
        },
        "_items": {
          "type": "array",
          "title": "Элементы",
          "items": {
            "type": "object",
            "properties": {
              "text": {
                "type": "string",
                "title": "Текст",
                "description": "Текст заголовка, отображаемый над вариантом сопоставления",
                "default": "",
                "_adapt": {
                  "translatable": true
                }
              },
              "_options": {
                "type": "array",
                "title": "Варианты",
                "items": {
                  "type": "object",
                  "properties": {
                    "text": {
                      "type": "string",
                      "title": "Текст",
                      "description": "Текст варианта",
                      "default": "",
                      "_adapt": {
                        "translatable": true
                      }
                    },
                    "_isCorrect": {
                      "type": "boolean",
                      "title": "Отметить этот вариант как правильный",
                      "default": false
                    }
                  }
                }
              }
            }
          }
        },
        "_feedback": {
          "type": "object",
          "title": "Обратная связь",
          "default": {},
          "properties": {
            "title": {
              "type": "string",
              "title": "Заголовок",
              "description": "Текст заголовка для обратной связи",
              "default": "",
              "_adapt": {
                "translatable": true
              }
            },
            "altTitle": {
              "type": "string",
              "title": "Альтернативный заголовок обратной связи",
              "description": "Текст, зачитываемый программами чтения с экрана, если нет визуального заголовка",
              "default": "",
              "_adapt": {
                "translatable": true
              }
            },
            "correct": {
              "type": "string",
              "title": "Правильная обратная связь",
              "description": "Обратная связь на правильный ответ на этот вопрос",
              "default": "",
              "_adapt": {
                "translatable": true
              },
              "_backboneForms": "TextArea"
            },
            "_incorrect": {
              "type": "object",
              "title": "Неправильно",
              "default": {},
              "properties": {
                "final": {
                  "type": "string",
                  "title": "Обратная связь по умолчанию для неправильного ответа",
                  "description": "Обратная связь на неправильный ответ для последней попытки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  },
                  "_backboneForms": "TextArea"
                },
                "notFinal": {
                  "type": "string",
                  "title": "Обратная связь для повторной попытки",
                  "description": "Обратная связь на неправильный ответ для любой попытки, кроме последней. Если вы оставите это поле пустым, будет использоваться обратная связь по умолчанию для неправильного ответа.",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  },
                  "_backboneForms": "TextArea"
                }
              }
            },
            "_partlyCorrect": {
              "type": "object",
              "title": "Частично правильно",
              "default": {},
              "properties": {
                "final": {
                  "type": "string",
                  "title": "Обратная связь по умолчанию для частично правильного ответа",
                  "description": "Обратная связь на частично правильный ответ для последней попытки. Если вы оставите это поле пустым, будет использоваться обратная связь по умолчанию для неправильного ответа.",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  },
                  "_backboneForms": "TextArea"
                },
                "notFinal": {
                  "type": "string",
                  "title": "Обратная связь для повторной попытки",
                  "description": "Обратная связь на частично правильный ответ для любой попытки, кроме последней. Если вы оставите это поле пустым, будет использоваться обратная связь по умолчанию для частично правильного ответа.",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  },
                  "_backboneForms": "TextArea"
                }
              }
            }
          }
        },
        "_buttons": {
          "type": "object",
          "title": "Переопределение кнопок",
          "default": {},
          "properties": {
            "_submit": {
              "type": "object",
              "title": "Отправить",
              "default": {},
              "properties": {
                "buttonText": {
                  "type": "string",
                  "title": "Текст кнопки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "ariaLabel": {
                  "type": "string",
                  "title": "Метка ARIA",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            },
            "_reset": {
              "type": "object",
              "title": "Сброс",
              "default": {},
              "properties": {
                "buttonText": {
                  "type": "string",
                  "title": "Текст кнопки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "ariaLabel": {
                  "type": "string",
                  "title": "Метка ARIA",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            },
            "_showCorrectAnswer": {
              "type": "object",
              "title": "Показать правильный ответ",
              "default": {},
              "properties": {
                "buttonText": {
                  "type": "string",
                  "title": "Текст кнопки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "ariaLabel": {
                  "type": "string",
                  "title": "Метка ARIA",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            },
            "_hideCorrectAnswer": {
              "type": "object",
              "title": "Скрыть правильный ответ",
              "default": {},
              "properties": {
                "buttonText": {
                  "type": "string",
                  "title": "Текст кнопки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "ariaLabel": {
                  "type": "string",
                  "title": "Метка ARIA",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            },
            "_showFeedback": {
              "type": "object",
              "title": "Показать обратную связь",
              "default": {},
              "properties": {
                "buttonText": {
                  "type": "string",
                  "title": "Текст кнопки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "ariaLabel": {
                  "type": "string",
                  "title": "Метка ARIA",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            },
            "remainingAttemptsText": {
              "type": "string",
              "title": "Метка оставшихся попыток",
              "default": "",
              "_adapt": {
                "translatable": true
              }
            },
            "remainingAttemptText": {
              "type": "string",
              "title": "Метка последней попытки",
              "default": "",
              "_adapt": {
                "translatable": true
              }
            }
          }
        }
      }
    }
  }
}
