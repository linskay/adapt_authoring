{
  "$anchor": "tutor-course",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$patch": {
    "source": {
      "$ref": "course"
    },
    "with": {
      "properties": {
        "_globals": {
          "type": "object",
          "default": {},
          "properties": {
            "_extensions": {
              "type": "object",
              "default": {},
              "properties": {
                "_tutor": {
                  "type": "object",
                  "title": "Тьютор",
                  "default": {},
                  "properties": {
                    "hideFeedback": {
                      "type": "string",
                      "title": "Скрыть обратную связь",
                      "default": "Скрыть обратную связь",
                      "_adapt": {
                        "translatable": true
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "_tutor": {
          "type": "object",
          "title": "Тьютор",
          "default": {},
          "properties": {
            "_type": {
              "type": "string",
              "title": "Тип",
              "description": "Тип отображения обратной связи по вопросу",
              "default": "notify",
              "enum": [
                "notify",
                "inline",
                "overlay",
                "none"
              ],
              "_backboneForms": "Select"
            },
            "_classes": {
              "type": "string",
              "title": "Классы",
              "description": "Классы обратной связи по вопросу",
              "default": ""
            },
            "_hasNotifyBottomButton": {
              "type": "boolean",
              "title": "Включить нижнюю кнопку уведомления",
              "description": "Если отключено и тип - notify, будет отображаться значок закрытия по умолчанию",
              "default": false
            },
            "_button": {
              "type": "object",
              "title": "Кнопка закрытия",
              "default": {},
              "properties": {
                "text": {
                  "type": "string",
                  "title": "Текст",
                  "description": "Для кнопок обратной связи notify и inline. Overlay всегда будет показывать крестик.",
                  "default": "{{_globals._extensions._tutor.hideFeedback}}",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "ariaLabel": {
                  "type": "string",
                  "title": "Метка ARIA",
                  "description": "Для кнопки inline и кнопки закрытия overlay. Notify всегда будет читать текст.",
                  "default": "{{_globals._extensions._tutor.hideFeedback}}",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
