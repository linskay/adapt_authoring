{
  "$anchor": "mcq-component",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$merge": {
    "source": {
      "$ref": "component"
    },
    "with": {
      "required": [
        "_attempts",
        "_selectable"
      ],
      "properties": {
        "_supportedLayout": {
          "type": "string",
          "title": "Поддерживаемый макет",
          "default": "half-width",
          "enum": [
            "full-width",
            "half-width",
            "both"
          ],
          "_adapt": {
            "editorOnly": true
          }
        },
        "instruction": {
          "type": "string",
          "title": "Инструкция",
          "default": "Выберите {{#if _isRadio}}один вариант{{else}}один или несколько вариантов{{/if}}, затем нажмите 'Отправить'.",
          "_adapt": {
            "translatable": true
          }
        },
        "ariaQuestion": {
          "type": "string",
          "title": "Вопрос ARIA",
          "description": "Это будет зачитано программами чтения с экрана вместо чтения полей 'Заголовок', 'Основной текст' и 'Инструкция' при фокусировке на вариантах. Чтобы быть ясным и кратким, убедитесь, что текст включает только связанный вопрос.",
          "default": "",
          "_adapt": {
            "translatable": true
          }
        },
        "_items": {
          "type": "array",
          "title": "Элементы",
          "description": "Возможные ответы, доступные учащемуся",
          "items": {
            "type": "object",
            "properties": {
              "text": {
                "type": "string",
                "title": "Текст",
                "description": "Этот текст будет отображаться как текст ответа",
                "default": "",
                "_adapt": {
                  "translatable": true
                }
              },
              "altText": {
                "type": "string",
                "title": "Альтернативный текст",
                "description": "Это будет зачитано программами чтения с экрана вместо чтения 'текста'. Необязательно для предоставления альтернативного текста, например, для указания того, как следует произносить слово.",
                "default": "",
                "_adapt": {
                  "translatable": true
                }
              },
              "_shouldBeSelected": {
                "type": "boolean",
                "title": "Отметить этот вариант как правильный",
                "default": false
              },
              "_isPartlyCorrect": {
                "type": "boolean",
                "title": "Отметить этот вариант как частично правильный",
                "default": false
              },
              "feedback": {
                "type": "string",
                "title": "Обратная связь по конкретному ответу",
                "description": "Когда для 'Выбираемых элементов' установлено значение 1, это можно использовать для предоставления пользователю обратной связи, специфичной для выбранного им ответа - если он неправильный",
                "default": "",
                "_adapt": {
                  "translatable": true
                },
                "_backboneForms": "TextArea"
              },
              "_score": {
                "type": "number",
                "title": "Оценка",
                "description": "Если включен подсчет очков по элементам, оценки за выбранные элементы суммируются, чтобы получить оценку за вопрос",
                "default": 0
              }
            }
          }
        },
        "_attempts": {
          "type": "number",
          "title": "Разрешенные попытки",
          "description": "Сколько попыток разрешено учащемуся",
          "default": 1
        },
        "_canShowModelAnswer": {
          "type": "boolean",
          "title": "Включить переключатель правильного ответа",
          "description": "Разрешить пользователю просматривать 'правильный ответ', если он ответил на вопрос неправильно",
          "default": true
        },
        "_canShowCorrectness": {
          "type": "boolean",
          "title": "Включить отображение правильности для элементов",
          "description": "Если включено, это заменяет соответствующую кнопку переключения 'правильного ответа' и отображает правильность непосредственно на элементах компонента.",
          "default": false
        },
        "_canShowFeedback": {
          "type": "boolean",
          "title": "Включить обратную связь",
          "default": true
        },
        "_canShowMarking": {
          "type": "boolean",
          "title": "Включить оценку",
          "default": true
        },
        "_shouldDisplayAttempts": {
          "type": "boolean",
          "title": "Показывать количество оставшихся попыток",
          "default": false
        },
        "_isRandom": {
          "type": "boolean",
          "title": "Перемешать ответы",
          "default": false
        },
        "_recordInteraction": {
          "type": "boolean",
          "title": "Записать взаимодействие",
          "description": "Если отключено, запись ответа(ов) пользователя на этот вопрос в cmi.interactions в LMS будет отключена только для этого компонента",
          "default": true
        },
        "_hasItemScoring": {
          "type": "boolean",
          "title": "Включить подсчет очков по элементам",
          "description": "Если отключено, этот вопрос оценивается в 0 баллов за неправильный ответ и в 'Вес вопроса' за правильный. Если включено, этот вопрос оценивается путем суммирования оценок выбранных вариантов",
          "default": false
        },
        "_questionWeight": {
          "type": "number",
          "title": "Вес вопроса",
          "description": "Когда подсчет очков по элементам отключен, это оценка за правильный ответ на вопрос",
          "default": 1
        },
        "_selectable": {
          "type": "number",
          "title": "Выбираемые элементы",
          "description": "Сколько элементов можно выбрать",
          "default": 1
        },
        "_feedback": {
          "type": "object",
          "title": "Обратная связь",
          "default": {},
          "properties": {
            "title": {
              "type": "string",
              "title": "Заголовок",
              "description": "Текст заголовка для обратной связи",
              "default": "",
              "_adapt": {
                "translatable": true
              }
            },
            "altTitle": {
              "type": "string",
              "title": "Альтернативный заголовок обратной связи",
              "description": "Текст, зачитываемый программами чтения с экрана, если визуальный заголовок отсутствует",
              "default": "",
              "_adapt": {
                "translatable": true
              }
            },
            "correct": {
              "type": "string",
              "title": "Правильная обратная связь",
              "description": "Обратная связь по правильному ответу на этот вопрос",
              "default": "",
              "_adapt": {
                "translatable": true
              },
              "_backboneForms": "TextArea"
            },
            "_incorrect": {
              "type": "object",
              "title": "Неправильно",
              "default": {},
              "properties": {
                "final": {
                  "type": "string",
                  "title": "Обратная связь по умолчанию для неправильного ответа",
                  "description": "Обратная связь по неправильному ответу для последней попытки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  },
                  "_backboneForms": "TextArea"
                },
                "notFinal": {
                  "type": "string",
                  "title": "Обратная связь при повторе",
                  "description": "Обратная связь по неправильному ответу для любой попытки, кроме последней. Если вы оставите это поле пустым, вместо него будет использоваться обратная связь по умолчанию для неправильного ответа.",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  },
                  "_backboneForms": "TextArea"
                }
              }
            },
            "_partlyCorrect": {
              "type": "object",
              "title": "Частично правильно",
              "default": {},
              "properties": {
                "final": {
                  "type": "string",
                  "title": "Обратная связь по умолчанию для частично правильного ответа",
                  "description": "Обратная связь по частично правильному ответу для последней попытки. Если вы оставите это поле пустым, вместо него будет использоваться обратная связь по умолчанию для неправильного ответа.",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  },
                  "_backboneForms": "TextArea"
                },
                "notFinal": {
                  "type": "string",
                  "title": "Обратная связь при повторе",
                  "description": "Обратная связь по частично правильному ответу для любой попытки, кроме последней. Если вы оставите это поле пустым, вместо него будет использоваться обратная связь по умолчанию для частично правильного ответа.",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  },
                  "_backboneForms": "TextArea"
                }
              }
            }
          }
        },
        "_buttons": {
          "type": "object",
          "title": "Переопределения кнопок",
          "default": {},
          "properties": {
            "_submit": {
              "type": "object",
              "title": "Отправить",
              "default": {},
              "properties": {
                "buttonText": {
                  "type": "string",
                  "title": "Текст кнопки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "ariaLabel": {
                  "type": "string",
                  "title": "Метка ARIA",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            },
            "_reset": {
              "type": "object",
              "title": "Сброс",
              "default": {},
              "properties": {
                "buttonText": {
                  "type": "string",
                  "title": "Текст кнопки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "ariaLabel": {
                  "type": "string",
                  "title": "Метка ARIA",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            },
            "_showCorrectAnswer": {
              "type": "object",
              "title": "Показать правильный ответ",
              "default": {},
              "properties": {
                "buttonText": {
                  "type": "string",
                  "title": "Текст кнопки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "ariaLabel": {
                  "type": "string",
                  "title": "Метка ARIA",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            },
            "_hideCorrectAnswer": {
              "type": "object",
              "title": "Скрыть правильный ответ",
              "default": {},
              "properties": {
                "buttonText": {
                  "type": "string",
                  "title": "Текст кнопки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "ariaLabel": {
                  "type": "string",
                  "title": "Метка ARIA",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            },
            "_showFeedback": {
              "type": "object",
              "title": "Показать обратную связь",
              "default": {},
              "properties": {
                "buttonText": {
                  "type": "string",
                  "title": "Текст кнопки",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "ariaLabel": {
                  "type": "string",
                  "title": "Метка ARIA",
                  "default": "",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            },
            "remainingAttemptsText": {
              "type": "string",
              "title": "Метка оставшихся попыток",
              "default": "",
              "_adapt": {
                "translatable": true
              }
            },
            "remainingAttemptText": {
              "type": "string",
              "title": "Метка последней попытки",
              "default": "",
              "_adapt": {
                "translatable": true
              }
            }
          }
        }
      }
    }
  }
}
