{
  "$anchor": "pageLevelProgress-course",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$patch": {
    "source": {
      "$ref": "course"
    },
    "with": {
      "properties": {
        "_globals": {
          "type": "object",
          "default": {},
          "properties": {
            "_extensions": {
              "type": "object",
              "default": {},
              "properties": {
                "_pageLevelProgress": {
                  "type": "object",
                  "title": "Прогресс на уровне страницы",
                  "default": {},
                  "properties": {
                    "pageLevelProgress": {
                      "type": "string",
                      "title": "Прогресс на уровне страницы",
                      "default": "Список разделов страницы и статус их завершения. Выберите незавершенные разделы, чтобы перейти непосредственно к содержимому.",
                      "_adapt": {
                        "translatable": true
                      }
                    },
                    "pageLevelProgressIndicatorBar": {
                      "type": "string",
                      "title": "Индикаторная полоса прогресса на уровне страницы",
                      "default": "Прогресс страницы. {{percentageComplete}}%. Открыть разделы страницы.",
                      "_adapt": {
                        "translatable": true
                      }
                    },
                    "pageLevelProgressMenuBar": {
                      "type": "string",
                      "title": "Панель меню прогресса на уровне страницы",
                      "default": "Завершение страницы {{percentageComplete}}%",
                      "_adapt": {
                        "translatable": true
                      }
                    },
                    "optionalContent": {
                      "type": "string",
                      "title": "Необязательное содержимое",
                      "default": "Необязательное содержимое",
                      "_adapt": {
                        "translatable": true
                      }
                    },
                    "_navOrder": {
                      "type": "number",
                      "title": "Порядок навигационной панели",
                      "description": "Определяет порядок, в котором прогресс на уровне страницы отображается на панели навигации. Отрицательные числа (например, -100) выравниваются по левому краю. Положительные числа (например, 100) выравниваются по правому краю.",
                      "default": 90
                    },
                    "_navTooltip": {
                      "type": "object",
                      "title": "Подсказка навигации по прогрессу на уровне страницы",
                      "properties": {
                        "_isEnabled": {
                          "type": "boolean",
                          "title": "Включить подсказку для кнопки навигации",
                          "default": true
                        },
                        "text": {
                          "type": "string",
                          "title": "",
                          "default": "Прогресс страницы",
                          "_adapt": {
                            "translatable": true
                          }
                        }
                      }
                    },
                    "_showLabel": {
                      "type": "boolean",
                      "title": "Включить метку кнопки навигационной панели",
                      "default": true
                    },
                    "navLabel": {
                      "type": "string",
                      "title": "Метка кнопки навигационной панели",
                      "default": "Прогресс страницы",
                      "_adapt": {
                        "translatable": true
                      }
                    },
                    "_drawerPosition": {
                      "type": "string",
                      "default": "auto",
                      "title": "Положение ящика",
                      "description": "Определяет начальное положение ящика для открытия",
                      "enum": [
                        "auto",
                        "left",
                        "right"
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "_pageLevelProgress": {
          "type": "object",
          "title": "Прогресс на уровне страницы",
          "default": {},
          "properties": {
            "_isEnabled": {
              "type": "boolean",
              "title": "Включить прогресс на уровне страницы",
              "default": true
            },
            "title": {
              "type": "string",
              "title": "Альтернативный заголовок",
              "description": "Альтернативный заголовок для отображения курса",
              "default": "",
              "_adapt": {
                "translatable": true
              }
            },
            "_showPageCompletion": {
              "type": "boolean",
              "title": "Включить общее завершение страницы",
              "description": "Если включено, общий прогресс курса будет рассчитываться для всех компонентов. Если отключено, в расчеты будут включены только те компоненты, которые настроены для отображения в «Прогрессе на уровне страницы». По умолчанию включено.",
              "default": true
            },
            "_isCompletionIndicatorEnabled": {
              "type": "boolean",
              "title": "Показывать встроенный индикатор завершения",
              "default": false
            },
            "_isShownInNavigationBar": {
              "type": "boolean",
              "title": "Показывать прогресс в навигационной панели",
              "default": true
            },
            "_showAtCourseLevel": {
              "type": "boolean",
              "title": "Отображать все объекты контента и компоненты текущей страницы",
              "description": "Контролирует, отображать ли все объекты контента и компоненты текущей страницы вместе, или только компоненты текущей страницы",
              "default": false
            },
            "_useCourseProgressInNavigationButton": {
              "type": "boolean",
              "title": "Использовать прогресс на уровне курса на кнопке навигации",
              "description": "Если включено, кнопка навигации будет показывать прогресс на уровне курса, а не на уровне страницы. По умолчанию отключено.",
              "default": false
            }
          }
        }
      }
    }
  }
}
