{
  "$anchor": "blank-component",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$merge": {
    "source": {
      "$ref": "component"
    },
    "with": {
      "properties": {
        "_isOptional": {
          "type": "boolean",
          "default": true,
          "isSetting": true,
          "inputType": "Checkbox",
          "validators": [],
          "title": "Это необязательно?",
          "help": "Необязательный компонент не должен быть завершен пользователем."
        },
        "_supportedLayout": {
          "type": "string",
          "title": "Поддерживаемый макет",
          "default": "both",
          "enum": [
            "full-width",
            "half-width",
            "both"
          ],
          "_adapt": {
            "editorOnly": true
          }
        },
        "displayTitle": {
          "type": "string",
          "title": "Отображаемый заголовок",
          "description": "При просмотре элемента - это заголовок, который будет отображаться на странице",
          "default": "",
          "_adapt": {
            "translatable": false
          },
          "_backboneForms": {
            "type": "DisplayTitle",
            "showInUi": false
          }
        },
        "body": {
          "type": "string",
          "title": "Тело",
          "default": "",
          "_adapt": {
            "translatable": false
          },
          "_backboneForms": {
            "type": "TextArea",
            "showInUi": false
          }
        },
        "instruction": {
          "type": "string",
          "title": "Инструкция",
          "default": "",
          "_adapt": {
            "translatable": true
          },
          "_backboneForms": {
            "showInUi": false
          }
        }
      }
    }
  }
}
