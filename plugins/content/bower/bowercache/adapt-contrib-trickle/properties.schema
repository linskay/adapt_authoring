                "_autoScroll": {
                  "type": "boolean",
                  "required": false,
                  "title": "Прокручивать автоматически",
                  "inputType": "Checkbox",
                  "validators": []
                },
                "_scrollDuration": {
                  "type": "number",
                  "required": true,
                  "default": 500,
                  "title": "Продолжительность прокрутки",
