                  "type": "string",
                  "required": false,
                  "enum": ["_isInteractionComplete", "_isComplete"],
                  "default": "_isComplete",
                  "title": "Атрибут завершения",
                  "inputType": {"type": "Select", "options":["_isInteractionComplete", "_isComplete"]},
                  "validators": [],
                  "help": "Установите, какой атрибут используется для определения завершения"
                },
                "_button": {
                  "type": "object",
                  "required": false,
                  "title": "Атрибуты кнопки",
                  "properties": {
                    "_isEnabled": {
                      "type": "boolean",
                      "required": false,
                      "default": true,
                      "title": "Включено",
                      "inputType": "Checkbox",
                      "validators": []
                    },
                    "_styleBeforeCompletion": {
                      "type": "string",
                      "required": false,
                      "enum": ["hidden", "visible", "disabled"],
                      "default": "hidden",
                      "title": "Начальная видимость",
                      "inputType": {"type": "Select", "options":["hidden", "visible", "disabled"]},
                      "help": "Установить видимость кнопки до завершения"
                    },
                    "_styleAfterClick": {
                      "type": "string",
                      "required": false,
                      "enum": ["hidden", "visible", "disabled"],
                      "default": "hidden",
                      "title": "Конечная видимость",
                      "inputType": {"type": "Select", "options":["hidden", "visible", "disabled"]},
                      "help": "Установить видимость кнопки после завершения"
                    },
                    "_isFullWidth": {
                      "type": "boolean",
                      "required": false,
                      "default": true,
                      "title": "Полная ширина",
                      "inputType": "Checkbox",
                      "validators": []
                    },
                    "_autoHide": {
                      "type": "boolean",
                      "required": false,
                      "default": false,
                      "title": "Скрывать при прокрутке",
                      "inputType": "Checkbox",
                      "validators": [],
                      "help": "Скрывает кнопку, когда она прокручивается из вида; не рекомендуется для использования в курсах, которые должны быть совместимы с программами чтения с экрана."
                    },
                    "_showEndOfPage": {
                      "type": "boolean",
                      "required": false,
                      "default": true,
                      "title": "Показывать кнопку в конце страницы",
                      "inputType": "Checkbox",
                      "validators": [],
                      "help": "Если установлено значение `false`, скрывает эту кнопку только в том случае, если она появляется в конце страницы."
                    },
                    "_className": {
                      "type": "string",
                      "required": false,
                      "default": "",
                      "title": "Пользовательские классы",
                      "inputType": "Text",
                      "validators": []
                    },
                    "_hasIcon": {
                      "type": "boolean",
                      "required": false,
                      "default": false,
                      "title": "Включить иконку кнопки",
                      "inputType": "Checkbox",
                      "validators": [],
                      "help": "Отображает значок рядом с текстом кнопки Постепенная подача или вместо него. Значок по умолчанию - маленькая стрелка вниз"
                    },
                    "text": {
                      "type": "string",
                      "required": false,
                      "default": "Продолжить",
                      "title": "Текст кнопки",
                      "inputType": "Text",
                      "validators": [],
                      "translatable": true
                    },
                    "ariaLabel": {
                      "type": "string",
                      "required": false,
                      "default": "Продолжить",
                      "title": "Метка ARIA кнопки",
                      "inputType": "Text",
                      "validators": [],
                      "translatable": true
                    },
                    "disabledText": {
                      "type": "string",
                      "required": false,
                      "default": "",
                      "title": "Текст кнопки в отключенном состоянии",
                      "inputType": "Text",
                      "validators": [],
                      "translatable": true,
                      "help": "Этот текст может отображаться, когда кнопка отключена"
                    },
                    "disabledAriaLabel": {
                      "type": "string",
                      "required": false,
                      "default": "Продолжить",
                      "title": "Метка ARIA кнопки в отключенном состоянии",
                      "inputType": "Text",
                      "validators": [],
                      "translatable": true,
                      "help": "Метка aria, когда установлен «Текст кнопки в отключенном состоянии»"
                    },
                    "startText": {
                      "type": "string",
                      "required": false,
                      "default": "Начать",
                      "title": "Текст первой кнопки",
                      "inputType": "Text",
                      "validators": [],
                      "help": "Только для статей, когда для 'Включить на дочерних блоках' установлено значение true",
                      "translatable": true
                    },
                    "startAriaLabel": {
                      "type": "string",
                      "required": false,
                      "default": "Начать",
                      "title": "Метка ARIA первой кнопки",
                      "inputType": "Text",
                      "validators": [],
                      "help": "Только для статей, когда для 'Включить на дочерних блоках' установлено значение true",
                      "translatable": true
                    },
                    "finalText": {
                      "type": "string",
                      "required": false,
                      "default": "Завершить",
                      "title": "Текст последней кнопки",
                      "inputType": "Text",
                      "validators": [],
                      "help": "Только для статей, когда для 'Включить на дочерних блоках' установлено значение true",
                      "translatable": true
                    },
                    "finalAriaLabel": {
                      "type": "string",
                      "required": false,
                      "default": "Завершить",
                      "title": "Метка ARIA последней кнопки",
                      "inputType": "Text",
                      "validators": [],
                      "help": "Только для статей, когда для 'Включить на дочерних блоках' установлено значение true",
                      "translatable": true
                    },
