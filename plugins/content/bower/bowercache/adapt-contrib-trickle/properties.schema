                      "type": "string",
                      "required": false,
                      "default": "trickle-button",
                      "title": "Плагин постепенной подачи",
                      "inputType": "Text",
                      "validators": []
                    }
                  }
                },
                "_stepLocking": {
                  "type": "object",
                  "required": false,
                  "title": "Атрибуты блокировки шага",
                  "properties": {
                    "_isEnabled": {
                      "type": "boolean",
                      "required": false,
                      "default": true,
                      "title": "Включено",
                      "inputType": "Checkbox",
