{
  "$anchor": "trickle-article",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$patch": {
    "source": {
      "$ref": "article"
    },
    "with": {
      "properties": {
        "_trickle": {
          "type": "object",
          "title": "Постепенная подача",
          "default": {},
          "required": [
            "_scrollDuration"
          ],
          "properties": {
            "_isEnabled": {
              "type": "boolean",
              "title": "Включить постепенную подачу",
              "default": false
            },
            "_autoScroll": {
              "type": "boolean",
              "title": "Прокручивать автоматически",
              "default": false
            },
            "_scrollDuration": {
              "type": "number",
              "title": "Продолжительность прокрутки",
              "description": "Продолжительность анимации прокрутки в миллисекундах",
              "default": 500
            },
            "_onChildren": {
              "type": "boolean",
              "title": "Включить на дочерних блоках",
              "description": "Установите значение false для статьи, чтобы использовать постепенную подачу на уровне статьи",
              "default": false
            },
            "_scrollTo": {
              "type": "string",
              "title": "Цель прокрутки",
              "description": "Установите, как прокручивается постепенная подача",
              "default": "@block +1"
            },
            "_completionAttribute": {
              "type": "string",
              "title": "Атрибут завершения",
              "description": "Установите, какой атрибут используется для определения завершения",
              "default": "_isComplete",
              "enum": [
                "_isInteractionComplete",
                "_isComplete"
              ],
              "_backboneForms": "Select"
            },
            "_button": {
              "type": "object",
              "title": "Кнопка",
              "default": {},
              "required": [
                "_styleBeforeCompletion",
                "_styleAfterClick"
              ],
              "properties": {
                "_isEnabled": {
                  "type": "boolean",
                  "title": "Добавить кнопку постепенной подачи",
                  "default": false
                },
                "_styleBeforeCompletion": {
                  "type": "string",
                  "title": "Видимость до завершения",
                  "default": "hidden",
                  "enum": [
                    "hidden",
                    "visible",
                    "disabled"
                  ],
                  "_backboneForms": "Select"
                },
                "_styleAfterClick": {
                  "type": "string",
                  "title": "Видимость после завершения",
                  "default": "hidden",
                  "enum": [
                    "hidden",
                    "visible",
                    "disabled"
                  ],
                  "_backboneForms": "Select"
                },
                "_isFullWidth": {
                  "type": "boolean",
                  "title": "Сделать полной ширины",
                  "default": true
                },
                "_autoHide": {
                  "type": "boolean",
                  "title": "Скрывать кнопку, когда она больше не видна",
                  "description": "Скрывает кнопку, когда она прокручивается из вида; не рекомендуется для использования в курсах, которые должны быть совместимы с программами чтения с экрана",
                  "default": false
                },
                "_showEndOfPage": {
                  "type": "boolean",
                  "title": "Показывать кнопку в конце страницы",
                  "default": true
                },
                "_className": {
                  "type": "string",
                  "title": "Пользовательские классы",
                  "default": ""
                },
                "_hasIcon": {
                  "type": "boolean",
                  "title": "Включить иконку",
                  "description": "Отображает значок рядом с текстом кнопки Постепенная подача или вместо него. Значок по умолчанию - маленькая стрелка вниз",
                  "default": false
                },
                "text": {
                  "type": "string",
                  "title": "Текст кнопки по умолчанию",
                  "default": "Продолжить",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "ariaLabel": {
                  "type": "string",
                  "title": "Метка ARIA кнопки по умолчанию",
                  "default": "Продолжить",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "disabledText": {
                  "type": "string",
                  "title": "Текст кнопки в отключенном состоянии",
                  "default": "",
                  "description": "Этот текст может отображаться, когда кнопка отключена",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "disabledAriaLabel": {
                  "type": "string",
                  "title": "Метка ARIA кнопки в отключенном состоянии",
                  "default": "",
                  "description": "Метка aria, когда установлен «Текст кнопки в отключенном состоянии»",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "startText": {
                  "type": "string",
                  "title": "Текст первой кнопки",
                  "description": "Только для статей, когда для 'Включить на дочерних блоках' установлено значение true",
                  "default": "Начать",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "startAriaLabel": {
                  "type": "string",
                  "title": "Метка ARIA первой кнопки",
                  "description": "Только для статей, когда для 'Включить на дочерних блоках' установлено значение true",
                  "default": "Начать",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "finalText": {
                  "type": "string",
                  "title": "Текст последней кнопки",
                  "description": "Только для статей, когда для 'Включить на дочерних блоках' установлено значение true",
                  "default": "Завершить",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "finalAriaLabel": {
                  "type": "string",
                  "title": "Метка ARIA последней кнопки",
                  "description": "Только для статей, когда для 'Включить на дочерних блоках' установлено значение true",
                  "default": "Завершить",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "_component": {
                  "type": "string",
                  "title": "Плагин постепенной подачи",
                  "default": "trickle-button"
                }
              }
            },
            "_stepLocking": {
              "type": "object",
              "title": "Блокировка шага",
              "default": {},
              "properties": {
                "_isEnabled": {
                  "type": "boolean",
                  "title": "Скрыть последующий контент",
                  "default": true
                },
                "_isCompletionRequired": {
                  "type": "boolean",
                  "title": "Требовать завершения контента",
                  "default": true
                },
                "_isLockedOnRevisit": {
                  "type": "boolean",
                  "title": "Сбрасывать состояние при повторном посещении",
                  "default": false
                }
              }
            }
          }
        }
      }
    }
  }
}
