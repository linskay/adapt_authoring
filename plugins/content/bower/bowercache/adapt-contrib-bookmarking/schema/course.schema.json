{
  "$anchor": "bookmarking-course",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$patch": {
    "source": {
      "$ref": "course"
    },
    "with": {
      "properties": {
        "_globals": {
          "type": "object",
          "default": {},
          "properties": {
            "_extensions": {
              "type": "object",
              "default": {},
              "properties": {
                "_bookmarking": {
                  "type": "object",
                  "title": "Закладки",
                  "default": {},
                  "properties": {
                    "resumeButtonText": {
                      "type": "string",
                      "title": "Текст кнопки возобновления",
                      "default": "Возобновить",
                      "_adapt": {
                        "translatable": true
                      }
                    },
                    "resumeButtonAriaLabel": {
                      "type": "string",
                      "title": "Метка ARIA для возобновления",
                      "default": "Перейдите к самой дальней точке вашего прогресса.",
                      "_adapt": {
                        "translatable": true
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "_bookmarking": {
          "type": "object",
          "title": "Закладки",
          "default": {},
          "required": [
            "_level",
            "title"
          ],
          "properties": {
            "_isEnabled": {
              "type": "boolean",
              "title": "Включить закладки",
              "description": "Контролирует, включено или отключено расширение закладок",
              "default": true
            },
            "_level": {
              "type": "string",
              "title": "Уровень",
              "description": "Позволяет установить, будет ли создание закладок выполняться на уровне страницы, блока или компонента",
              "default": "component",
              "enum": [
                "page",
                "block",
                "component"
              ],
              "_backboneForms": "Select"
            },
            "_location": {
              "type": "string",
              "title": "Местоположение",
              "description": "Позволяет установить, будут ли закладки возвращать учащихся к их последнему посещенному месту или к самому дальнему незавершенному месту. Опция 'самый дальний' лучше всего подходит для курса с линейным прохождением.",
              "default": "previous",
              "enum": [
                "previous",
                "furthest"
              ],
              "_backboneForms": "Select"
            },
            "_showPrompt": {
              "type": "boolean",
              "title": "Включить подсказку",
              "description": "Контролирует, включена или отключена подсказка для закладок. Если не включено, пользователь будет автоматически возвращен на свою позицию с закладкой",
              "default": true
            },
            "_autoRestore": {
              "type": "boolean",
              "title": "Автоматическое восстановление",
              "description": "Контролирует, будут ли закладки автоматически восстанавливаться, если подсказка отключена. Если не включено, пользователь не будет автоматически возвращен на свою позицию с закладкой.",
              "default": true
            },
            "title": {
              "type": "string",
              "title": "Заголовок подсказки",
              "default": "Закладки",
              "_adapt": {
                "translatable": true
              }
            },
            "body": {
              "type": "string",
              "title": "Основной текст подсказки",
              "default": "Хотите продолжить с того места, где остановились?",
              "_adapt": {
                "translatable": true
              }
            },
            "_buttons": {
              "type": "object",
              "title": "Кнопки подсказки",
              "default": {},
              "properties": {
                "yes": {
                  "type": "string",
                  "title": "Текст кнопки подтверждения",
                  "default": "Да",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "no": {
                  "type": "string",
                  "title": "Текст кнопки отмены",
                  "default": "Нет",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
