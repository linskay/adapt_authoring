{
  "$anchor": "bookmarking-contentobject",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$patch": {
    "source": {
      "$ref": "contentobject"
    },
    "with": {
      "properties": {
        "_bookmarking": {
          "type": "object",
          "title": "Закладки",
          "default": {},
          "required": [
            "_level"
          ],
          "properties": {
            "_isEnabled": {
              "type": "boolean",
              "title": "Включить закладки",
              "description": "Контролирует, включены или отключены закладки для этой страницы курса",
              "default": true
            },
            "_level": {
              "type": "string",
              "title": "Уровень",
              "description": "Хотите ли вы унаследовать настройку 'Уровень' из настроек проекта или переопределить ее для этой страницы курса",
              "default": "inherit",
              "enum": [
                "inherit",
                "page",
                "block",
                "component"
              ],
              "_backboneForms": "Select"
            }
          }
        }
      }
    }
  }
}
