                  "default": "Просмотреть ссылки пользовательского типа 3",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "custom4Aria": {
                  "type": "string",
                  "title": "Пользовательский тип 4",
                  "default": "Просмотреть ссылки пользовательского типа 4",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "custom5Aria": {
                  "type": "string",
                  "title": "Пользовательский тип 5",
                  "default": "Просмотреть ссылки пользовательского типа 5",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "custom6Aria": {
                  "type": "string",
                  "title": "Пользовательский тип 6",
                  "default": "Просмотреть ссылки пользовательского типа 6",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "custom7Aria": {
                  "type": "string",
                  "title": "Пользовательский тип 7",
                  "default": "Просмотреть ссылки пользовательского типа 7",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "custom8Aria": {
                  "type": "string",
                  "title": "Пользовательский тип 8",
                  "default": "Просмотреть ссылки пользовательского типа 8",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "custom9Aria": {
                  "type": "string",
                  "title": "Пользовательский тип 9",
                  "default": "Просмотреть ссылки пользовательского типа 9",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "custom10Aria": {
                  "type": "string",
                  "title": "Пользовательский тип 10",
                  "default": "Просмотреть ссылки пользовательского типа 10",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            },
            "_resourcesItems": {
              "type": "array",
              "title": "Элементы",
              "items": {
                "type": "object",
                "properties": {
                  "_type": {
                    "type": "string",
                    "title": "Тип",
                    "enum": [
                      "document",
                      "media",
                      "link",
                      "custom1",
                      "custom2",
                      "custom3",
                      "custom4",
                      "custom5",
                      "custom6",
                      "custom7",
                      "custom8",
                      "custom9",
                      "custom10"
                    ],
                    "_backboneForms": "Select"
                  },
                  "_forceDownload": {
                    "type": "boolean",
                    "title": "Принудительная загрузка",
                    "description": "Принудительно загружает ресурс, а не открывает его в браузере. Поддерживается только в браузерах, которые поддерживают атрибут 'download', и для ресурсов, которые являются частью содержимого курса/размещены на том же URL-адресе.",
                    "default": false
                  },
                  "title": {
                    "type": "string",
                    "title": "Заголовок",
                    "_adapt": {
                      "translatable": true
                    }
                  },
                  "filename": {
                    "type": "string",
                    "title": "Имя файла",
                    "description": "Используется для установки имени загружаемого файла, отличного от имени исходного файла. Поддерживается только в браузерах, которые поддерживают атрибут 'download', и для ресурсов, которые являются частью содержимого курса/размещены на том же URL-адресе. Принудительно загружает файл независимо от того, что установлено для 'Принудительной загрузки'.",
                    "default": "",
                    "_adapt": {
                      "translatable": true
                    }
                  },
                  "description": {
                    "type": "string",
                    "title": "Описание",
                    "default": "",
                    "_adapt": {
                      "translatable": true
                    }
                  },
                  "_link": {
                    "type": "string",
                    "title": "Источник",
                    "_backboneForms": "Asset"
                  },
                  "_isGlobal": {
                    "type": "boolean",
                    "title": "Отображается на каждой странице",
                    "default": true
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
