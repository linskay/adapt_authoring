{
  "$anchor": "resources-course",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$patch": {
    "source": {
      "$ref": "course"
    },
    "with": {
      "properties": {
        "_globals": {
          "type": "object",
          "default": {},
          "properties": {
            "_extensions": {
              "type": "object",
              "default": {},
              "properties": {
                "_resources": {
                  "type": "object",
                  "title": "Ресурсы",
                  "default": {},
                  "properties": {
                    "ariaRegion": {
                      "type": "string",
                      "title": "Область ARIA",
                      "default": "",
                      "_adapt": {
                        "translatable": true
                      }
                    },
                    "resources": {
                      "type": "string",
                      "title": "Ресурсы",
                      "default": "Дополнительные ресурсы.",
                      "_adapt": {
                        "translatable": true
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "_resources": {
          "type": "object",
          "title": "Ресурсы",
          "default": {},
          "required": [
            "title"
          ],
          "properties": {
            "_isEnabled": {
              "type": "boolean",
              "title": "Добавить ссылки на ресурсы в ящик",
              "description": "Определяет, включено или отключено расширение 'Ресурсы'.",
              "default": true
            },
            "_drawerOrder": {
              "type": "number",
              "title": "Позиция в ящике",
              "description": "Порядок, в котором это расширение должно отображаться как элемент ящика",
              "default": 0
            },
            "title": {
              "type": "string",
              "title": "Заголовок",
              "default": "Ресурсы",
              "description": "Заголовок для кнопки ресурсов, который отображается, когда более одного расширения использует ящик.",
              "_adapt": {
                "translatable": true
              }
            },
            "description": {
              "type": "string",
              "title": "Описание",
              "default": "Выберите здесь, чтобы просмотреть ресурсы для этого курса",
              "description": "Текст описания для кнопки ресурсов, который отображается, когда более одного расширения использует ящик.",
              "_adapt": {
                "translatable": true
              }
            },
            "displayTitle": {
              "type": "string",
              "title": "Отображаемый заголовок",
              "default": "",
              "description": "Заголовок для ресурсов, который отображается в верхней части ящика ресурсов.",
              "_adapt": {
                "translatable": true
              }
            },
            "body": {
              "type": "string",
              "title": "Основной текст",
              "default": "",
              "description": "Основной текст для ресурсов, который отображается в верхней части ящика ресурсов.",
              "_adapt": {
                "translatable": true
              }
            },
            "instruction": {
              "type": "string",
              "title": "Инструкция",
              "default": "",
              "description": "Текст инструкции для ресурсов, который отображается в верхней части ящика ресурсов.",
              "_adapt": {
                "translatable": true
              }
            },
            "_enableFilters": {
              "type": "boolean",
              "title": "Включить кнопки фильтра",
              "default": true,
              "description": "Включает и выключает кнопки фильтра. Обратите внимание, что кнопки фильтра будут автоматически отключены, если все элементы ресурсов имеют одинаковое значение типа."
            },
            "_filterButtons": {
              "type": "object",
              "title": "Кнопки фильтра",
              "default": {},
              "properties": {
                "all": {
                  "type": "string",
                  "title": "Все",
                  "default": "Все",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "document": {
                  "type": "string",
                  "title": "Документы",
                  "default": "Документы",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "media": {
                  "type": "string",
                  "title": "Медиа",
                  "default": "Медиа",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "link": {
                  "type": "string",
                  "title": "Ссылки",
                  "default": "Ссылки",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "custom1": {
                  "type": "string",
                  "title": "Пользовательский тип 1",
                  "default": "Пользовательский тип 1",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "custom2": {
                  "type": "string",
                  "title": "Пользовательский тип 2",
                  "default": "Пользовательский тип 2",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "custom3": {
                  "type": "string",
                  "title": "Пользовательский тип 3",
                  "default": "Пользовательский тип 3",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "custom4": {
                  "type": "string",
                  "title": "Пользовательский тип 4",
                  "default": "Пользовательский тип 4",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "custom5": {
                  "type": "string",
                  "title": "Пользовательский тип 5",
                  "default": "Пользовательский тип 5",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "custom6": {
                  "type": "string",
                  "title": "Пользовательский тип 6",
                  "default": "Пользовательский тип 6",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "custom7": {
                  "type": "string",
                  "title": "Пользовательский тип 7",
                  "default": "Пользовательский тип 7",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "custom8": {
                  "type": "string",
                  "title": "Пользовательский тип 8",
                  "default": "Пользовательский тип 8",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "custom9": {
                  "type": "string",
                  "title": "Пользовательский тип 9",
                  "default": "Пользовательский тип 9",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "custom10": {
                  "type": "string",
                  "title": "Пользовательский тип 10",
                  "default": "Пользовательский тип 10",
                  "_adapt": {
                    "translatable": true
                  }
                }
              }
            },
            "_filterAria": {
              "type": "object",
              "title": "Метки ARIA фильтра",
              "default": {},
              "properties": {
                "allAria": {
                  "type": "string",
                  "title": "Все",
                  "default": "Просмотреть все ресурсы",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "documentAria": {
                  "type": "string",
                  "title": "Документы",
                  "default": "Просмотреть ресурсы документов",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "mediaAria": {
                  "type": "string",
                  "title": "Медиа",
                  "default": "Просмотреть медиаресурсы",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "linkAria": {
                  "type": "string",
                  "title": "Ссылки",
                  "default": "Просмотреть ссылки на ресурсы",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "custom1Aria": {
                  "type": "string",
                  "title": "Пользовательский тип 1",
                  "default": "Просмотреть ссылки пользовательского типа 1",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "custom2Aria": {
                  "type": "string",
                  "title": "Пользовательский тип 2",
                  "default": "Просмотреть ссылки пользовательского типа 2",
                  "_adapt": {
                    "translatable": true
                  }
                },
                "custom3Aria": {
                  "type": "string",
