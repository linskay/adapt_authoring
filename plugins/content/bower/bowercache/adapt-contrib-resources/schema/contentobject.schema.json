{
  "$anchor": "resources-contentobject",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "$patch": {
    "source": {
      "$ref": "contentobject"
    },
    "with": {
      "properties": {
        "_resources": {
          "type": "object",
          "title": "Ресурсы",
          "default": {},
          "properties": {
            "_isEnabled": {
              "type": "boolean",
              "title": "Добавить ссылки на ресурсы в ящик",
              "description": "Определяет, включено или отключено расширение 'Ресурсы'.",
              "default": true
            },
            "_resourcesItems": {
              "type": "array",
              "title": "Элементы",
              "items": {
                "type": "object",
                "properties": {
                  "_type": {
                    "type": "string",
                    "title": "Тип",
                    "enum": [
                      "document",
                      "media",
                      "link"
                    ],
                    "_backboneForms": "Select"
                  },
                  "_forceDownload": {
                    "type": "boolean",
                    "title": "Принудительная загрузка",
                    "description": "Принудительно загружает ресурс, а не открывает его в браузере. Поддерживается только в браузерах, которые поддерживают атрибут 'download', и для ресурсов, которые являются частью содержимого курса/размещены на том же URL-адресе.",
                    "default": false
                  },
                  "title": {
                    "type": "string",
                    "title": "Заголовок",
                    "_adapt": {
                      "translatable": true
                    }
                  },
                  "filename": {
                    "type": "string",
                    "title": "Имя файла",
                    "description": "Используется для установки имени загружаемого файла, отличного от имени исходного файла. Поддерживается только в браузерах, которые поддерживают атрибут 'download', и для ресурсов, которые являются частью содержимого курса/размещены на том же URL-адресе. Принудительно загружает файл независимо от того, что установлено для 'Принудительной загрузки'.",
                    "default": "",
                    "_adapt": {
                      "translatable": true
                    }
                  },
                  "description": {
                    "type": "string",
                    "title": "Описание",
                    "default": "",
                    "_adapt": {
                      "translatable": true
                    }
                  },
                  "_link": {
                    "type": "string",
                    "title": "Источник",
                    "_backboneForms": "Asset"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
